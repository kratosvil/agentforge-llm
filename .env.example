# Ollama
OLLAMA_HOST=http://localhost:11434
MODEL_NAME=qwen2.5-coder:7b

# Concurrency — reduce to 1 if RAM < 2GB free during execution
MAX_PARALLEL_TASKS=2

# Paths — defaults to subdirectories inside the project root if not set
# RESULTS_DIR=/absolute/path/to/agentforge-llm/results
# MANIFESTS_DIR=/absolute/path/to/agentforge-llm/manifests
# AUDIT_DIR=/absolute/path/to/agentforge-llm/audit
# TEMPLATES_DIR=/absolute/path/to/agentforge-llm/templates

# Timeout per task in seconds (300 = 5 min)
TASK_TIMEOUT_SECONDS=300
